rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isRecipeAuthor(recipeId) {
      return isAuth() &&
        get(/databases/$(database)/documents/recipes/$(recipeId)).data.authorId == request.auth.uid;
    }

    // Campos permitidos ao criar uma receita
    function validRecipeCreate() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'authorId', 'isPublished', 'createdAt', 'updatedAt'])
          && data.authorId == request.auth.uid
          && data.title is string
          && data.title.size() > 0
          && data.likesCount == 0
          && data.favoritesCount == 0
          && data.commentsCount == 0;
    }

    // Campos que o autor pode atualizar (não pode mexer em contadores de interação diretamente)
    function validRecipeUpdate() {
      let forbidden = ['authorId', 'createdAt', 'likesCount', 'favoritesCount', 'commentsCount'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(forbidden)
          || onlyInteractionUpdate();
    }

    // Permite apenas atualização de likesCount + likedBy (interação autenticada)
    function onlyInteractionUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuth() && changed.hasOnly(['likesCount', 'likedBy']);
    }

    // ── users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Qualquer um pode ler perfis públicos
      allow read: if true;

      // Só o próprio usuário pode criar/atualizar seu documento
      allow create: if isOwner(userId);

      allow update: if isOwner(userId)
          && !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['uid', 'email', 'createdAt', 'recipesCount', 'followersCount', 'followingCount']);

      // Nunca permite deletar conta pelo cliente
      allow delete: if false;
    }

    // ── recipes ──────────────────────────────────────────────────────────────

    match /recipes/{recipeId} {
      // Leitura de documento único: publicado ou próprio rascunho
      allow get: if resource.data.isPublished == true
          || isOwner(resource.data.authorId);
      // Queries (lista/busca): apenas usuários autenticados
      allow list: if isAuth();

      // Apenas usuários autenticados podem criar
      allow create: if isAuth() && validRecipeCreate();

      // Autor pode editar; qualquer autenticado pode dar like
      allow update: if isOwner(resource.data.authorId) && validRecipeUpdate()
          || onlyInteractionUpdate();

      // Só o autor pode deletar
      allow delete: if isOwner(resource.data.authorId);

      // ── comments ────────────────────────────────────────────────────────

      match /comments/{commentId} {
        // Comentários de receitas publicadas são públicos
        allow read: if get(/databases/$(database)/documents/recipes/$(recipeId)).data.isPublished == true;

        // Usuário autenticado pode comentar e o comentário deve ter o authorId correto
        allow create: if isAuth()
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 1000;

        // Só o autor do comentário pode editar (apenas o campo text)
        allow update: if isOwner(resource.data.authorId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text']);

        // Autor do comentário ou autor da receita podem deletar
        allow delete: if isOwner(resource.data.authorId) || isRecipeAuthor(recipeId);
      }
    }

    // ── reports ──────────────────────────────────────────────────────────────

    match /reports/{reportId} {
      // Apenas o próprio denunciante pode ler sua denúncia
      allow read: if isOwner(resource.data.reporterId);

      // Usuário autenticado pode criar denúncia com seu próprio uid
      allow create: if isAuth()
          && request.resource.data.reporterId == request.auth.uid;

      // Imutável após criação
      allow update, delete: if false;
    }

    // ── Bloqueia todo o resto ────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
